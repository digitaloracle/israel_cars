{
  "manifest_version": 3,
  "name": "Israel Vehicle Lookup",
  "version": "1.0.0",
  "description": "Query Israeli vehicle registration, mileage, and ownership history from data.gov.il",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://data.gov.il/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Israel Vehicle Lookup"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
